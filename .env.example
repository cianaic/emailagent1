# Copy this file to .env and fill in your values

# Supabase (for auth + Google OAuth)
# Configure the Google provider in your Supabase dashboard (Authentication > Providers > Google).
# The app requests Gmail and Calendar scopes through Supabase's OAuth flow — no separate
# Google client credentials are needed here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key (server-side only — NOT exposed to client)
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key (for Contact Intelligence — fast LLM classification)
GROQ_API_KEY=gsk_...

# Notion (for Contact Intelligence CRM sync — optional)
NOTION_API_KEY=ntn_...
NOTION_PARENT_PAGE_ID=your-page-id

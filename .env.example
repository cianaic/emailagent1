# Copy this file to .env and fill in your values

# Supabase (for auth + Google OAuth + Contact Intelligence storage)
# Configure the Google provider in your Supabase dashboard (Authentication > Providers > Google).
# The app requests Gmail and Calendar scopes through Supabase's OAuth flow — no separate
# Google client credentials are needed here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key (server-side only — NOT exposed to client)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key (for Contact Intelligence — fast LLM classification)
GEMINI_API_KEY=your-gemini-api-key
